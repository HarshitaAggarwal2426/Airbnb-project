<% layout("/layouts/boilerplate") %>
<!-- <script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
</script> -->
<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>
  <div class="card col-6 offset-3 show-card listing-card">
    <img
      src="<%= listing.image.url %>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <p class="card-text">Owned by <i><%= listing.owner.username %></i></p>
      <p class="card-text"><%= listing.description %></p>
      <p class="card-text">
        &#8377; <%= listing.price.toLocaleString("en-IN") %>
      </p>
      <p class="card-text"><%= listing.location %></p>
      <p class="card-text"><%= listing.country %></p>
    </div>
  </div>

  <br />

    <% if(currUser && listing.owner._id.toString() !== currUser._id.toString()) { %>
  <div class="col-6 offset-3 mb-3">
    <hr />
    <h4>Book this place</h4>

    <form action="/listings/<%= listing._id %>/bookings" method="POST">
      <!-- <div class="mb-2">
        <label>Check In:</label>
        <input 
          type="date" 
          name="checkIn" 
          class="form-control" 
          required 
          min="<%= new Date().toISOString().split('T')[0] %>"
        >  
      </div>

      <div class="mb-2">
        <label>Check Out:</label>
        <input 
          type="date" 
          name="checkOut" 
          class="form-control" 
          required 
          min="<%= new Date().toISOString().split('T')[0] %>"
        > 
      </div> -->
      <div class="mb-2">
        <label>Select Dates:</label>
        <input 
          type="text" 
          id="bookingDate" 
          class="form-control" 
          placeholder="Select dates"
          required
        >
      </div>

      <input type="hidden" name="checkIn" id="checkIn">
      <input type="hidden" name="checkOut" id="checkOut">

      <div class="mt-3 border rounded p-3">

  <p>
    <strong>Price per night:</strong>
    ₹ <%= listing.price.toLocaleString("en-IN") %>
  </p>

  <p>
    <strong>Total Nights:</strong>
    <span id="totalNights">0</span>
  </p>

  <p>
    <strong>Total Price:</strong>
    ₹ <span id="totalPrice">0</span>
  </p>

</div>

      <button class="btn btn-dark mt-2" id="bookBtn">Book Now</button>
    </form>
  </div>
<% } %>

<% if(currUser && listing.owner._id.toString() === currUser._id.toString()) { %>
  <div class="btns">
    <a
      href="/listings/<%= listing._id %>/edit"
      class="btn btn-dark col-1 offset-3 edit-btn"
      >Edit
    </a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
      <button class="btn btn-dark offset-5">Delete</button>
    </form>
  </div>

  <% } %>
  <div class="col-8 offset-3 mb-3">
    <% if(currUser && hasBooked) { %>
    <hr />
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%= listing.id %>/reviews"
      method="POST"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <fieldset class="starability-slot">
          <input
            type="radio"
            id="no-rate"
            class="input-no-rate"
            name="review[rating]"
            value="1"
            checked
            aria-label="No rating."
          />
          <input
            type="radio"
            id="first-rate1"
            name="review[rating]"
            value="1"
          />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input
            type="radio"
            id="first-rate2"
            name="review[rating]"
            value="2"
          />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input
            type="radio"
            id="first-rate3"
            name="review[rating]"
            value="3"
          />
          <label for="first-rate3" title="Average">3 stars</label>
          <input
            type="radio"
            id="first-rate4"
            name="review[rating]"
            value="4"
          />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input
            type="radio"
            id="first-rate5"
            name="review[rating]"
            value="5"
          />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="30"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please add some comments for review</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr />
    <% } %> <% if(listing.reviews.length >0) { %>
    <div class="row">
      <p><b>All Reviews</b></p>
      <% for(review of listing.reviews) { %>
      <div class="card col-5 ms-3 mb-3">
        <div class="card-body">
          <h5 class="card-title">@<%= review.author.username%></h5>
          <p
            class="starability-result card-text"
            data-rating="<%= review.rating %>"
          ></p>

          <p class="card-text"><%= review.comment %></p>
        </div>
        <form
          class="mb-3"
          method="POST"
          action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
        >
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
      </div>
      <% } %>
    </div>
    <% } %>
  </div>
  <div class="col-8 offset-3 mb-3">
    <h3>Where you'll be</h3>
    <div id="map">
      <script>
        const mapToken = "<%= process.env.MAP_TOKEN %>";
        const coordinates = JSON.parse(
          "<%- JSON.stringify(listing.geometry ? listing.geometry.coordinates : [0, 0]) %>"
        );
        const title = "<%= listing.title %>";
        const placeLocation = "<%= listing.location %>";
      </script>
    </div>
  </div>
</div>
<script>
  const form = document.querySelector("form");
  const btn = document.getElementById("bookBtn");

  if (form && btn) {
    form.addEventListener("submit", () => {
      btn.innerText = "Booking...";
      btn.disabled = true;
    });
  }
</script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="/js/map.js"></script>
<script>

const bookedDates = JSON.parse(
  '<%- JSON.stringify(bookedDates || []) %>'
);

  const listingPrice = Number("<%= listing.price %>");

  flatpickr("#bookingDate", {
    mode: "range",
    minDate: "today",
    dateFormat: "Y-m-d",

    disable: bookedDates,

    onChange: function(selectedDates) {

      if (selectedDates.length === 2) {

        // hidden input values
        document.getElementById("checkIn").value =
          selectedDates[0].toISOString().split("T")[0];

        document.getElementById("checkOut").value =
          selectedDates[1].toISOString().split("T")[0];

        // calculate nights
        const nights =
          (selectedDates[1] - selectedDates[0]) /
          (1000 * 60 * 60 * 24);

        // total price
        const totalPrice = nights * listingPrice;

        // update UI
        document.getElementById("totalNights").innerText = nights;

        document.getElementById("totalPrice").innerText =
          totalPrice.toLocaleString("en-IN");
      }

    }

  });

</script>